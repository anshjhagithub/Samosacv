# Mistral API key (SERVER-ONLY). Get one at https://console.mistral.ai
# Never use NEXT_PUBLIC_ for this key.
MISTRAL_API_KEY=your_mistral_api_key_here

# Optional: which Mistral model to use. Default: mistral-large-latest
# Upgrade for better quality: mistral-large-2 (newer flagship)
# Cheaper/faster: mistral-small-latest, mistral-medium-latest
# See https://docs.mistral.ai/guides/model-selection/
# MISTRAL_MODEL=mistral-large-latest

# Supabase (for Google login). Get from https://supabase.com/dashboard/project/_/settings/api
# Enable Google under Authentication → Providers and add your redirect URL under URL Configuration.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=

# Optional: for generation limits and payments (Supabase Edge Functions)
# CONFIRM_GENERATION_SECRET=your_secret

# Canonical site URL for SEO (sitemap, Open Graph, canonicals). Use production URL when deploying.
NEXT_PUBLIC_SITE_URL=https://samosacv.com

# Optional: Google Search Console verification (meta name="google-site-verification")
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_verification_code

# Optional: Bing Webmaster Tools verification (meta name="msvalidate.01")
# NEXT_PUBLIC_BING_SITE_VERIFICATION=your_bing_verification_code

# Cashfree Payment Gateway (SERVER: do not expose secret to client)
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=TEST
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_CASHFREE_ENV=TEST
